# 실제 값을 채운 뒤 .env 로 복사해서 사용하세요 (.env는 git에 커밋하지 마세요)

# 회사에서 받은 접속 문자열
DATABASE_URL=postgresql://app_260712_tosb_user.xxxxxxxxxxxx:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# 로그인 화면에서 입력할 비밀번호 (임의로 정해서 채우세요)
APP_PASSWORD=change-me

# 세션 쿠키 서명용 비밀키 (임의의 긴 무작위 문자열로 채우세요)
SESSION_SECRET=change-me-too

# 서버 포트
PORT=3000

# 정적 프론트가 서비스되는 오리진 (CORS 허용용).
# 이 서버가 프론트(index.html 등)까지 같은 오리진에서 서빙하므로(server/index.js의
# express.static 참고) 기본은 비워두면 됩니다. 프론트를 별도 호스팅으로 분리할 때만
# 그 오리진을 채우세요. 예: ALLOWED_ORIGIN=https://survey.example.com
ALLOWED_ORIGIN=
